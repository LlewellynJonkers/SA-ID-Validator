    <div class="card mb-4" style="max-width: 640px;">
        <div class="card-body">
            <h2 class="card-title">South African ID Validator</h2>
            <form id="saIdForm" class="row g-2">
                <div class="col-12 col-md-8">
                    <label class="form-label" for="saId">ID Number (13 digits):</label>
                    <input class="form-control" id="saId" maxlength="13" inputmode="numeric" pattern="\d*" placeholder="1234567890123" autocomplete="off" />
                </div>
                <div class="col-12 col-md-4 d-flex align-items-end gap-2">
                    <button type="button" id="pasteButton" class="btn btn-secondary w-100">Paste</button>
                    <button type="submit" id="validateButton" class="btn btn-primary w-100">Validate</button>
                </div>
            </form>
        </div>
    </div>
    <div id="result" class="mt-3 alert alert-info" style="display: none;"></div>
    <div class="mt-3">
        <h5>Validation Log:</h5>
        <ul id="log" class="list-group">
        </ul>
    </div>


    @section Scripts{

    <script>
        "use strict";
        var logEnabled = false; // set to false to disable log output
        function pasteClipboard() {
            navigator.clipboard.readText().then(text => {
                const input = document.getElementById('saId');
                input.focus();
                input.value = text.trim();
                log('Pasted from clipboard: ' + text.trim());
                validateSAID();
            }).catch(err => {
                log('Failed to read clipboard contents: ' + err);
            });
        }
        async function pasteClipboardAsync() {
            try {
                const permission = await navigator.permissions.query({ name: "clipboard-read" });

                if (permission.state === "denied") {
                    log("Clipboard access denied");
                    return;
                }

                const text = await navigator.clipboard.readText().trim().replace(" ",'');
                const input = document.getElementById('saId');
                input.focus();
                document.getElementById('saId').value = text.trim();
                log('Pasted: ' + text.trim());
                validateSAID();

            } catch (err) {
                try {
                    const text = await navigator.clipboard.readText();
                    document.getElementById('saId').value = text.trim();
                    validateSAID();
                } catch (err) {
                    console.error('Clipboard error:', err);
                }
            }
        }
        function log(message) {
            if (!logEnabled) return;
            const entry = document.createElement('li');
            entry.className = 'list-group-item text-muted small';
            entry.textContent = message;
            document.getElementById('log').appendChild(entry);
        }
        function clearLog() {
            document.getElementById('log').innerHTML = '';
        }
        function validateSAID() {
            clearLog();
            const raw = (document.getElementById('saId').value || '').trim();
            const id = raw.replace(/\D/g, ''); // remove non-digits
            const out = document.getElementById('result');
            out.innerHTML = '';
            out.style.display = 'none';
            out.className = 'mt-3 alert';

            if (id.length !== 13) {
                out.textContent = 'Invalid: ID must contain exactly 13 digits.';
                out.classList.add('alert-danger');
                out.style.display = 'block';
                return;
            }

            if (!/^\d{13}$/.test(id)) {
                out.textContent = 'Invalid: ID must contain only digits.';
                out.classList.add('alert-danger');
                out.style.display = 'block';
                return;
            }

            // Extract DOB YYMMDD
            const yy = parseInt(id.substr(0, 2), 10);
            log('Extracted year (2 digits): ' + yy);
            const mm = parseInt(id.substr(2, 2), 10);
            log('Extracted month: ' + mm);
            const dd = parseInt(id.substr(4, 2), 10);
            log('Extracted day: ' + dd);
            

            // Infer century: assume 2000+ if yy <= currentYear%100, else 1900+
            const now = new Date();
            const currentTwoDigit = now.getFullYear() % 100;
            let year = (yy <= currentTwoDigit) ? 2000 + yy : 1900 + yy;

            const dob = new Date(year, mm-1, dd, 0, 0, 0); // month is 0-indexed
            log('Constructed date of birth: ' + dob.toLocaleDateString().slice(0,10));

            // If constructed date doesn't match components, invalid
            const validDate = dob.getFullYear() === year && (dob.getMonth()+1) === mm && dob.getDate() === dd;

            // crude age sanity check: not older than 120 and not in future
            const age = validDate ? calculateAge(dob, now) : null;
            if (!validDate || age < 0 || age > 120) {
                out.textContent = 'Invalid: date of birth portion is not a valid DOB.';
                out.classList.add('alert-danger');
                out.style.display = 'block';
                return;
            }

            // Gender: digits 7-10 (indexes 6-9). If number >= 5000 => male else female
            const genderSeq = parseInt(id.substr(6, 4), 10);
            const gender = (genderSeq >= 5000) ? 'Male' : 'Female';

            // Nationality: 11th digit (index 10). 0 = SA citizen, 1 = permanent resident (per standard)
            const nationalityDigit = id.charAt(10);
            let nationality = 'Invalid';
            if (nationalityDigit === '0') nationality = 'SA citizen';
            else if (nationalityDigit === '1') nationality = 'Permanent resident';
            else if (nationalityDigit === '2') nationality = 'Refugee / Assylum Seeker'; // not standard but sometimes used

            
            // Luhn checksum validation (SA ID specific)
            const checksumValid = luhnCheck(id);

            // Build result
            const parts = [];
            parts.push('Valid ID checksum: ' + (checksumValid ? 'Yes' : 'No'));
            parts.push('Date of birth: ' + dob.toLocaleDateString('en-GB', {
                day: '2-digit',
                month: 'long',
                year: 'numeric'
            }));
            parts.push('Current age: ' + age + ' years');
            parts.push('Gender: ' + gender);
            parts.push('Nationality status digit: ' + nationalityDigit + ' (' + nationality + ')');

            setResult(parts.map(escapeHtml).map(p => `<div>${p}</div>`).join(''), checksumValid ? 'success' : 'warning');
        }

        function setResult(message, type) {
            const out = document.getElementById('result');
            out.innerHTML = message;
            out.className = `mt-3 alert alert-${type}`;
            out.style.display = 'block';
        }

        function calculateAge(dob, now) {
            let age = now.getFullYear() - dob.getFullYear();
            const m = now.getMonth() - dob.getMonth();
            if (m < 0 || (m === 0 && now.getDate() < dob.getDate())) age--;
            return age;
        }

        function luhnCheck(id) {
            // According to SA ID Luhn method:
            // 1) Sum digits in odd positions (1,3,5,7,9,11)
            // 2) Concatenate digits in even positions (2,4,6,8,10,12), multiply by 2, sum digits of result
            // 3) Add both sums, subtract last digit of total from 10 -> checksum (0 if result is 10)
            // Compare with 13th digit.
            let sumOdd = 0;
            for (let i = 0; i <= 10; i += 2) { // indexes 0,2,4,6,8,10 -> positions 1,3,5,7,9,11
                sumOdd += parseInt(id.charAt(i), 10);
            }

            let evenConc = '';
            for (let i = 1; i <= 11; i += 2) { // indexes 1,3,5,7,9,11 -> positions 2,4,6,8,10,12
                evenConc += id.charAt(i);
            }

            const evenProduct = (parseInt(evenConc, 10) * 2).toString();
            let sumEvenDigits = 0;
            for (let ch of evenProduct) {
                sumEvenDigits += parseInt(ch, 10);
            }

            const total = sumOdd + sumEvenDigits;
            const checkDigit = (10 - (total % 10)) % 10;
            return checkDigit === parseInt(id.charAt(12), 10);
        }

        function escapeHtml(str) {
            return str.replace(/[&<>"']/g, function (m) {
                return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m];
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('saIdForm').addEventListener('submit', (e) => {
                e.preventDefault();
                validateSAID();
            });
            document.getElementById('pasteButton').addEventListener('click', pasteClipboardAsync);
        });
    </script>
    }
